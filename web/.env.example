# Frontend env (Vite). Copy to web/.env for local overrides, or set in Vercel.
#
# Base URL of the backend API. Leave BLANK for local dev — Vite proxies /api to
# localhost:3000. In production (Vercel) set this to the Render backend URL,
# e.g. https://hiring-tracker-api.onrender.com
VITE_API_BASE=
